@incollection{Siebers2017EABSS,
  author = {Siebers, Peer-Olaf and Kl{\"u}gl, Franziska},
  title = {What Software Engineering Has to Offer to Agent-Based Social Simulation},
  booktitle = {Simulating Social Complexity: A Handbook},
  editor = {Edmonds, Bruce and Meyer, Ruth},
  publisher = {Springer},
  series = {Understanding Complex Systems},
  year = {2017},
  pages = {81--117},
  doi = {10.1007/978-3-319-66948-9_6},
  keywords = {type:methodology, ABSS, EABSS, software_engineering, agent_based_modeling, methodology},
  abstract = {This chapter introduces the Engineering Agent-Based Social Simulation (EABSS) framework, which adapts software engineering practices to the development of agent-based social simulation models. The framework provides a structured workflow that helps modellers move from problem definition to implementation while maintaining transparency and rigour. EABSS forms the methodological foundation for a programme of agent-based social simulation research and is extensively cited in subsequent work on rigorous, reproducible ABM development.}
}

@article{Achter2022RATRS,
  author = {Achter, Sebastian and Borit, Melania and Chattoe-Brown, Edmund and Siebers, Peer-Olaf},
  title = {{RAT-RS}: A Reporting Standard for Improving the Documentation of Data Use in Agent-Based Modelling},
  journal = {International Journal of Social Research Methodology},
  year = {2022},
  volume = {25},
  number = {4},
  pages = {517--540},
  doi = {10.1080/13645579.2022.2049511},
  publisher = {Taylor \& Francis},
  keywords = {type:methodology, reporting_standard, RAT-RS, ABM, reproducibility, rigor, documentation},
  abstract = {The paper introduces RAT-RS (Rigour and Transparency Reporting Standard), a structured reporting protocol for documenting how empirical data are used in agent-based models. Building on prior protocols such as ODD, RAT-RS focuses on data provenance, transformation, and integration with model components. The standard is designed to improve reproducibility, transparency, and methodological rigour in agent-based modelling, and has direct applicability to LLM-augmented ABM where data flows are increasingly opaque.}
}

@article{Siebers2025AIBuddy,
  author = {Siebers, Peer-Olaf},
  title = {An {AI} Buddy for Agent-Based Social Simulation Modelling Using the {EABSS} Framework},
  journal = {Journal of Artificial Societies and Social Simulation},
  year = {2025},
  volume = {28},
  number = {3},
  doi = {10.18564/jasss.5681},
  keywords = {type:workflow, LLM, EABSS, AI_assistant, ABSS, modelling_workflow},
  abstract = {This paper proposes an LLM-based ``AI Buddy'' that assists modellers throughout the EABSS workflow, from conceptualisation to implementation. The AI Buddy supports tasks such as requirements elicitation, conceptual modelling, code generation, and documentation, while preserving human oversight at each stage. The work demonstrates how large language models can be integrated as collaborative partners in rigorous agent-based social simulation development, and discusses the implications for transparency, reproducibility, and modeller skill development.}
}

@article{Gao2024LLMABM,
  author = {Gao, Chen and Lan, Xiaochong and Li, Nian and Yuan, Yuan and Ding, Jingtao and Zhou, Zhilun and Xu, Fengli and Li, Yong},
  title = {Large Language Models Empowered Agent-Based Modeling and Simulation: A Survey and Perspectives},
  journal = {Humanities and Social Sciences Communications},
  year = {2024},
  volume = {11},
  pages = {1259},
  doi = {10.1057/s41599-024-03611-3},
  publisher = {Nature Publishing Group},
  keywords = {type:survey, LLM, ABM, agent_based_modeling, survey, taxonomy},
  abstract = {This survey systematically reviews how large language models are empowering agent-based modelling and simulation across four application domains: cyber, physical, social, and hybrid systems. The authors propose a taxonomy of LLM-driven ABM approaches, analyse the architecture of LLM-empowered agents, and identify open challenges including evaluation, scalability, and reliability. As one of the most authoritative external surveys in this rapidly evolving area, the work serves as a key reference for situating LLM-augmented ABSS within the broader landscape.}
}

@article{Ghaffarzadegan2024GABM,
  author = {Ghaffarzadegan, Navid and Majumdar, Aritra and Williams, Ross and Hosseinichimeh, Niyousha},
  title = {Generative Agent-Based Modeling: An Introduction and Tutorial},
  journal = {System Dynamics Review},
  year = {2024},
  volume = {40},
  number = {1},
  pages = {e1761},
  doi = {10.1002/sdr.1761},
  publisher = {Wiley},
  keywords = {type:tutorial, GABM, LLM_agents, generative_agents, social_norms, simulation, agent_decision},
  abstract = {This tutorial introduces Generative Agent-Based Modeling (GABM), in which agent decision rules are replaced or augmented by large language models. The authors illustrate the approach with a model of social-norm diffusion inside an organisation, where each agent's behaviour is generated by an LLM rather than coded as fixed rules. The paper discusses calibration, prompt sensitivity, and the implications of stochastic LLM outputs for simulation reproducibility, and provides a hands-on starting point for researchers building LLM-driven ABMs.}
}

@inproceedings{Park2023GenerativeAgents,
  author = {Park, Joon Sung and O'Brien, Joseph C. and Cai, Carrie J. and Morris, Meredith Ringel and Liang, Percy and Bernstein, Michael S.},
  title = {Generative Agents: Interactive Simulacra of Human Behavior},
  booktitle = {Proceedings of the 36th Annual ACM Symposium on User Interface Software and Technology ({UIST} '23)},
  year = {2023},
  publisher = {ACM},
  doi = {10.1145/3586183.3606763},
  keywords = {type:foundational, generative_agents, LLM_agents, simulation, social_behavior, memory_architecture},
  abstract = {This paper introduces generative agents -- computational agents whose behaviour is produced by a large language model coupled with a memory stream, reflection, and planning architecture. The authors deploy 25 such agents in an interactive sandbox town and observe believable individual and emergent social behaviours, including spontaneous information diffusion, relationship formation, and coordination. The work has become a foundational reference for generative agent-based modelling and informs the design of LLM-driven agent decision-making in social simulations.}
}

@article{Argyle2023OutOfOne,
  author = {Argyle, Lisa P. and Busby, Ethan C. and Fulda, Nancy and Gubler, Joshua R. and Rytting, Christopher and Wingate, David},
  title = {Out of One, Many: Using Language Models to Simulate Human Samples},
  journal = {Political Analysis},
  year = {2023},
  volume = {31},
  number = {3},
  pages = {337--351},
  doi = {10.1017/pan.2023.2},
  publisher = {Cambridge University Press},
  keywords = {type:empirical, LLM, silicon_sampling, human_simulation, validity, agent_decision},
  abstract = {This paper investigates whether large language models can serve as ``silicon samples'' that faithfully reproduce the response distributions of human subgroups. Using GPT-3 conditioned on demographic backstories, the authors compare model outputs against US survey data on political attitudes and find substantial alignment for several subgroups. The work raises and partially answers the question of whether LLM-driven agents in generative ABM can be treated as credible stand-ins for real human populations, and identifies the conditions under which such substitution is and is not warranted.}
}

@article{Birhane2023Science,
  author = {Birhane, Abeba and Kasirzadeh, Atoosa and Leslie, David and Wachter, Sandra},
  title = {Science in the Age of Large Language Models},
  journal = {Nature Reviews Physics},
  year = {2023},
  volume = {5},
  number = {5},
  pages = {277--280},
  doi = {10.1038/s42254-023-00581-4},
  publisher = {Nature Publishing Group},
  keywords = {type:ethics, LLM, scientific_integrity, ethics, reliability, risks},
  abstract = {Four leading AI ethics researchers jointly examine systemic risks that arise when large language models are integrated into scientific research. The commentary discusses hallucination, opacity, evaluation difficulty, and the concentration of epistemic authority in a handful of model providers, arguing that uncritical adoption of LLMs threatens the integrity of scientific knowledge production. The piece is a touchstone reference for any work that uses LLMs as research instruments, including LLM-augmented agent-based simulation, where reliability and reproducibility are paramount.}
}

@article{Zou2025StockMARL,
  author = {Zou, Zhaoyi and Siebers, Peer-Olaf},
  title = {{StockMARL}: A Multi-Agent Reinforcement Learning Framework for Transparent Stock Market Simulation},
  journal = {Procedia Computer Science},
  year = {2025},
  volume = {274},
  doi = {10.1016/j.procs.2025.12.091},
  publisher = {Elsevier},
  keywords = {type:case_study, MARL, multi_agent_reinforcement_learning, transparency, stock_market, simulation},
  abstract = {StockMARL presents a multi-agent reinforcement learning framework for stock market simulation that emphasises transparency in how learned agent policies relate to observable market dynamics. The paper documents the model design, training regime, and analysis pipeline, and discusses how transparency mechanisms can be retained when traditional rule-based agents are replaced by learned controllers. Within a programme on rigorous ABSS, the work serves as a contrasting case to LLM-driven agents: both replace hand-coded rules, but with very different implications for interpretability, reproducibility, and validation.}
}
